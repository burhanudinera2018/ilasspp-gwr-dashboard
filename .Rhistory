# =====================================================
# RINGKASAN EKSEKUTIF HASIL ANALISIS GWR
# =====================================================
# Hitung statistik ringkasan
ringkasan <- data.frame(
  Metrik = c(
    "Jumlah sampel",
    "Bandwidth optimal",
    "R-squared global",
    "Koefisien Lebar Jalan (min)",
    "Koefisien Lebar Jalan (median)",
    "Koefisien Lebar Jalan (max)",
    "Koefisien Jarak (min / paling negatif)",
    "Koefisien Jarak (median)",
    "Koefisien Jarak (max / mendekati 0)"
  ),
  Nilai = c(
    nrow(data_sf),
    paste(round(bw, 2), "meter"),
    round(gwr_model$results$r2, 4),
    round(min(data_sf$coef_lebar_jalan), 5),
    round(median(data_sf$coef_lebar_jalan), 5),
    round(max(data_sf$coef_lebar_jalan), 5),
    round(min(data_sf$coef_jarak), 5),
    round(median(data_sf$coef_jarak), 5),
    round(max(data_sf$coef_jarak), 5)
  )
)
print(ringkasan)
# Simpan ringkasan
write.csv(ringkasan, "ringkasan_gwr_ilaspp.csv", row.names = FALSE)
# =====================================================
# RINGKASAN EKSEKUTIF HASIL ANALISIS GWR (DIPERBAIKI)
# =====================================================
# Cek dulu nama-nama hasil yang tersedia di gwr_model
names(gwr_model$results)
# Ambil R-squared yang benar (gunakan quasi-global R2 dari output sebelumnya)
# Dari output GWR Anda, nilai Quasi-global R2 = 0.9691279
r2_value <- 0.9691279
# Buat data frame ringkasan dengan penulisan yang benar
ringkasan <- data.frame(
  Metrik = c(
    "Jumlah sampel",
    "Bandwidth optimal",
    "R-squared global (Quasi-global R2)",
    "Koefisien Lebar Jalan (min)",
    "Koefisien Lebar Jalan (median)",
    "Koefisien Lebar Jalan (max)",
    "Koefisien Jarak (min / paling negatif)",
    "Koefisien Jarak (median)",
    "Koefisien Jarak (max / mendekati 0)"
  ),
  Nilai = c(
    nrow(data_sf),                                      # jumlah sampel
    paste(round(bw, 2), "meter"),                       # bandwidth
    round(r2_value, 4),                                 # R-squared
    round(min(data_sf$coef_lebar_jalan), 5),            # min lebar jalan
    round(median(data_sf$coef_lebar_jalan), 5),         # median lebar jalan
    round(max(data_sf$coef_lebar_jalan), 5),       
# Ambil R-squared yang  rint(ringkasan)
# Simpan ringkasan ke CSV
write.csv(ringkasan, "ringkasan_gwr_ilaspp.csv", row.names = FALSE)
# Konfirmasi
cat("✅ Ringkasan tersimpan di:", getwd(), "/ringkasan_gwr_ilaspp.csv\n")
# 1. Lihat ringkasan sederhana di console
cat("\n========== RINGKASAN HASIL GWR ==========\n")
# 2. Jumlah sampel
cat("Jumlah sampel:", nrow(data_sf), "\n")
# 3. Bandwidth
cat("Bandwidth optimal:", round(bw, 2), "meter\n")
# 4. R-squared (gunakan dari output sebelumnya)
cat("Quasi-global R2: 0.9691\n")
# 5. Koefisien Lebar Jalan
cat("\n--- Koefisien Lebar Jalan ---\n")
cat("Minimum:", round(min(data_sf$coef_lebar_jalan), 5), "\n")
cat("Median:", round(median(data_sf$coef_lebar_jalan), 5), "\n")
cat("Maximum:", round(max(data_sf$coef_lebar_jalan), 5), "\n")
# 6. Koefisien Jarak
cat("\n--- Koefisien Jarak ---\n")
cat("Minimum (paling negatif):", round(min(data_sf$coef_jarak), 5), "\n")
cat("Median:", round(median(data_sf$coef_jarak), 5), "\n")
cat("Maximum (mendekati 0):", round(max(data_sf$coef_jarak), 5), "\n")
# 7. Tampilkan tabel koefisien per kabupaten (ringkas)
cat("\n--- TABEL KOEFISIEN PER KABUPATEN ---\n")
print(data.frame(
  Kabupaten = data_sf$nama_kabupaten,
  Lebar_Jalan = round(data_sf$coef_lebar_jalan, 4),
  Jarak = round(data_sf$coef_jarak, 4)
))
# Buat teks ringkasan
sink("ringkasan_gwr_ilaspp.txt")
cat("========== RINGKASAN HASIL GWR - PROYEK ILASPP ==========\n\n")
cat("Tanggal analisis:", date(), "\n\n")
cat("--- STATISTIK MODEL ---\n")
cat("Jumlah sampel:", nrow(data_sf), "\n")
cat("Bandwidth optimal:", round(bw, 2), "meter\n")
cat("Quasi-global R2: 0.9691\n\n")
cat("--- KOEFISIEN LEBAR JALAN ---\n")
cat("Minimum:", round(min(data_sf$coef_lebar_jalan), 5), "\n")
cat("Median:", round(median(data_sf$coef_lebar_jalan), 5), "\n")
cat("Maximum:", round(max(data_sf$coef_lebar_jalan), 5), "\n\n")
cat("--- KOEFISIEN JARAK KE PUSAT KOTA ---\n")
cat("Minimum (paling negatif):", round(min(data_sf$coef_jarak), 5), "\n")
cat("Median:", round(median(data_sf$coef_jarak), 5), "\n")
cat("Maximum (mendekati 0):", round(max(data_sf$coef_jarak), 5), "\n\n")
cat("--- TABEL KOEFISIEN PER KABUPATEN ---\n")
for(i in 1:nrow(data_sf)) {
  cat(data_sf$nama_kabupaten[i], "| Lebar Jalan:", round(data_sf$coef_lebar_jalan[i], 4), 
      "| Jarak:", round(data_sf$coef_jarak[i], 4), "\n")
}
sink()
cat("\n✅ Ringkasan tersimpan di:", getwd(), "/ringkasan_gwr_ilaspp.txt\n")
q()
