# Install package jika belum
# install.packages(c("patchwork", "cowplot"))
library(ggplot2)
library(patchwork)
install.packages(patchwork)
install.packages("patchwork")
# 1. Plot koefisien lebar jalan (Bubble Map)
p1 <- ggplot(data_sf) +
  geom_sf(aes(size = coef_lebar_jalan, fill = coef_lebar_jalan), 
          alpha = 0.8, shape = 21, color = "black") +
  geom_sf_text(aes(label = nama_kabupaten), size = 2.5, 
               nudge_y = 0.05, check_overlap = TRUE) +
  scale_fill_viridis_c(option = "plasma", name = "Koefisien") +
  scale_size_continuous(range = c(4, 12), guide = "none") +
  labs(title = "A. Pengaruh Lebar Jalan",
       subtitle = "Semakin besar titik = semakin kuat pengaruh") +
  theme_minimal() +
  theme(legend.position = "bottom")
# 2. Plot koefisien jarak (Bubble Map)
p2 <- ggplot(data_sf) +
  geom_sf(aes(size = abs(coef_jarak), fill = coef_jarak), 
          alpha = 0.8, shape = 21, color = "black") +
  geom_sf_text(aes(label = nama_kabupaten), size = 2.5, 
               nudge_y = 0.05, check_overlap = TRUE) +
  scale_fill_gradient2(low = "blue", mid = "white", high = "red", 
                       midpoint = -0.003, name = "Koefisien") +
  scale_size_continuous(range = c(4, 12), guide = "none") +
  labs(title = "B. Pengaruh Jarak ke Pusat Kota",
       subtitle = "Biru = negatif (semakin jauh semakin murah)") +
  theme_minimal() +
  theme(legend.position = "bottom")
# 3. Bar chart koefisien lebar jalan
p3 <- ggplot(data_sf, aes(x = reorder(nama_kabupaten, coef_lebar_jalan), 
                          y = coef_lebar_jalan, fill = coef_lebar_jalan)) +
  geom_col() +
  geom_text(aes(label = round(coef_lebar_jalan, 4)), 
            hjust = -0.1, size = 3) +
  coord_flip() +
  scale_fill_viridis_c(option = "plasma", guide = "none") +
  labs(title = "C. Ranking Pengaruh Lebar Jalan",
       x = "", y = "Koefisien (log harga per meter)") +
  theme_minimal()
# 4. Bar chart koefisien jarak
p4 <- ggplot(data_sf, aes(x = reorder(nama_kabupaten, -coef_jarak), 
                          y = coef_jarak, fill = coef_jarak)) +
  geom_col() +
  geom_text(aes(label = round(coef_jarak, 4)), 
            hjust = -0.1, size = 3) +
  coord_flip() +
  scale_fill_gradient2(low = "blue", mid = "white", high = "red", 
                       midpoint = -0.003, guide = "none") +
  labs(title = "D. Ranking Pengaruh Jarak (Negatif)",
       x = "", y = "Koefisien (log harga per km)") +
  theme_minimal()
# Gabungkan semua plot
(p1 + p2) / (p3 + p4) +
  plot_annotation(
    title = "Hasil Analisis GWR - Proyek ILASPP",
    subtitle = "Pengaruh Lebar Jalan dan Jarak ke Pusat Kota terhadap Harga Tanah",
    caption = "Sumber: Analisis Data ILASPP | Metode: Geographically Weighted Regression"
  )
