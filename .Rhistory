# 1. Ambil hasil koefisien dari model GWR
gwr_results <- as.data.frame(gwr_model$SDF)
# 2. Lihat nama-nama kolom yang tersedia di gwr_results
names(gwr_results)
# 2. Tambahkan kolom hasil ke data_sf dengan nama kolom yang benar
data_sf$coef_lebar_jalan <- gwr_results$X_lebar_jalan     # Perhatikan: X_lebar_jalan (bukan X_lebari_jalan)
data_sf$coef_jarak <- gwr_results$X_jarak
data_sf$local_r2 <- gwr_results$localR2
data_sf$intercept <- gwr_results$X.Intercept.
# 3. Cek apakah kolom sudah terbentuk
head(data_sf)
