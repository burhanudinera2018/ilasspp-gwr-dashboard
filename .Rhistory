data_sf <- st_as_sf(data, coords = c("longitude", "latitude"), crs = 4326))
data_sf <- st_as_sf(data, coords = c("longitude", "latitude"), crs = 4326)
install.packages("sf")
library(sf)
data_sf <- st_as_sf(data, coords = c("longitude", "latitude"), crs = 4326)
colnames(data)
data_sf <- st_as_sf(data, coords = c("lng", "lat"), crs = 4326)
print(data_sf)
plot(data_sf$geometry)
plot(data_sf$geometry)
names(data_sf)
# Transformasi log karena distribusi tidak normal
data_sf$log_harga <- log(data_sf$Y)
# GWR formula
formula_gwr <- log_harga ~ X_lebar_jalan + X_jarak
head(data_sf)
head(data_sf)
model_ols <- lm(log(harga_per_m2) ~ lebar_jalan_m + jarak_ke_pusat_km + 
                log(luas_tanah_m2) + tahun_sertifikat, 
                data = data)
# 1. Load packages
library(sf)
library(spgwr)
install.packages("spgwr")
library(spgwr)
# 2. Konversi ke format sp (jika belum)
data_sp <- as(data_sf, "Spatial")
# 3. OLS Model (Global Regression)
model_ols <- lm(log_harga ~ X_lebar_jalan + X_jarak, data = data_sp)
cat("\n=== HASIL OLS (REGRESI GLOBAL) ===\n")
summary(model_ols)
# 4. Bandingkan AIC OLS
aic_ols <- AIC(model_ols)
cat("\nAIC OLS:", round(aic_ols, 2), "\n")
# 5. Bandwidth Selection untuk GWR
cat("\n=== MENGHITUNG BANDWIDTH OPTIMAL ===\n")
bw <- gwr.sel(log_harga ~ X_lebar_jalan + X_jarak, 
              data = data_sp, 
              adapt = FALSE, 
              verbose = FALSE)
cat("Bandwidth optimal:", round(bw, 2), "meter\n")
 6. Jalankan GWR
gwr_model <- gwr(log_harga ~ X_lebar_jalan + X_jarak,
                 data = data_sp,
                 bandwidth = bw,
                 hatmatrix = TRUE)
# 7. Hasil GWR
cat("\n=== HASIL GWR ===\n")
print(gwr_model)
# 8. Bandingkan AIC GWR dengan OLS
aic_gwr <- gwr_model$results$AICc
cat("\n=== PERBANDINGAN MODEL ===\n")
cat("AIC OLS :", round(aic_ols, 2), "\n")
cat("AICc GWR:", round(aic_gwr, 2), "\n")
cat("Selisih (GWR - OLS):", round(aic_gwr - aic_ols, 2), "\n")
if (aic_gwr < aic_ols) {
  cat("✅ GWR lebih baik dari OLS (AIC lebih rendah)\n")
} else {
  cat("⚠️ OLS cukup, GWR tidak memberikan peningkatan signifikan\n")
}
# 9. Ekstrak koefisien lokal
gwr_results <- as.data.frame(gwr_model$SDF)
cat("\n=== KOEFISIEN LOKAL PER WILAYAH ===\n")
print(data.frame(
  Kabupaten = data_sf$nama_kabupaten,
  Coef_Lebar_Jalan = round(gwr_results$X_lebar_jalan, 4),
  Coef_Jarak = round(gwr_results$X_jarak, 4),
  Local_R2 = round(gwr_results$localR2, 4)
))
# 10. Visualisasi sederhana
plot(data_sp$X_lebar_jalan, gwr_results$X_lebar_jalan,
     xlab = "Lebar Jalan (nilai aktual)",
     ylab = "Koefisien GWR Lebar Jalan",
     main = "Variasi Spasial Pengaruh Lebar Jalan")
abline(h = coef(model_ols)[2], col = "red", lwd = 2)
text(data_sp$X_lebar_jalan, gwr_results$X_lebar_jalan,
     labels = data_sf$nama_kabupaten, pos = 4, cex = 0.7)
legend("topright", legend = c("Rata-rata OLS"), col = "red", lty = 1)
