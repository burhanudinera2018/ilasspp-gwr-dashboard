  Kabupaten = data_sf$nama_kabupaten,
  Koefisien_Lebar_Jalan = round(data_sf$coef_lebar_jalan, 4),
  Koefisien_Jarak = round(data_sf$coef_jarak, 4),
  R2_Lokal = round(data_sf$local_r2, 4)
))
# Load package
library(ggplot2)
# Peta koefisien lebar jalan
ggplot(data_sf) +
  geom_sf(aes(size = coef_lebar_jalan, color = coef_lebar_jalan), alpha = 0.8) +
  geom_sf_text(aes(label = nama_kabupaten), size = 3, nudge_y = 0.05) +
  scale_color_viridis_c(option = "plasma", name = "Koefisien\nLebar Jalan") +
  scale_size_continuous(range = c(5, 15), name = "Koefisien") +
  labs(title = "Pengaruh Lebar Jalan terhadap Harga Tanah",
       subtitle = "Hasil Analisis GWR - Proyek ILASPP") +
